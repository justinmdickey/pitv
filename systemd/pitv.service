[Unit]
Description=PiTV Video Looper
After=multi-user.target sound.target
Wants=sound.target

[Service]
Type=simple
User=__USER__
Environment=HOME=__HOME__
ExecStartPre=/bin/sleep 5
ExecStart=__HOME__/pitv/scripts/pitv-player.sh
Restart=always
RestartSec=5
Nice=-5
KillSignal=SIGTERM
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
